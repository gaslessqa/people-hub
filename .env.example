# ============================================================================
#* AI-DRIVEN SOFTWARE PROJECT - ENVIRONMENT VARIABLES
# ============================================================================
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values (see comments below)
# 3. Never commit .env to git (it's in .gitignore)
#
# Documentation: docs/mcp-builder-strategy.md
# ============================================================================

# ----------------------------------------------------------------------------
#* MCP BUILDER CONFIGURATION (Required for AI tools integration)
# ----------------------------------------------------------------------------
# See: docs/mcp-builder-strategy.md for detailed setup instructions

# Path to your MCP catalog file (contains ALL available MCPs with your API keys)
# This file is NOT committed to git and contains your secrets
# Example values:
#   - Gemini CLI:    '.gemini/settings.catalog.json'
#   - Claude Code:   '.mcp.catalog.json'
#   - Cursor:        '.cursor/mcp.catalog.json'
MCP_CATALOG_FILE='.gemini/settings.catalog.json'

# Path to the active MCP config file (auto-generated by mcp-builder.js)
# This is the file your AI tool actually reads
# Example values:
#   - Gemini CLI:    '.gemini/settings.json'
#   - Claude Code:   '.mcp.json'
#   - Cursor:        '.cursor/mcp.json'
MCP_FILE='.gemini/settings.json'

# Path to your AI CLI binary (OPTIONAL - only needed for auto-launch)
# Leave empty or omit if you prefer to launch your AI tool manually
# Example values:
#   - Gemini CLI:    '/path/to/gemini' or '~/.nvm/versions/node/vX.X.X/bin/gemini'
#   - Claude Code:   '/usr/local/bin/claude'
#   - Cursor:        '/usr/local/bin/cursor'
AI_COMMAND_PATH=''

# ----------------------------------------------------------------------------
#* ALTERNATIVE CONFIGURATIONS (Examples for different AI tools)
# ----------------------------------------------------------------------------
# Uncomment and use the configuration that matches your AI tool:

# Claude Code (Anthropic CLI):
# MCP_CATALOG_FILE='.mcp.catalog.json'
# MCP_FILE='.mcp.json'
# AI_COMMAND_PATH='/usr/local/bin/claude'

# GitHub Copilot CLI:
# MCP_CATALOG_FILE='.copilot/mcp.catalog.json'
# MCP_FILE='.copilot/mcp.json'
# AI_COMMAND_PATH=''

# Cursor IDE:
# MCP_CATALOG_FILE='.cursor/mcp.catalog.json'
# MCP_FILE='.cursor/mcp.json'
# AI_COMMAND_PATH='/usr/local/bin/cursor'

# ----------------------------------------------------------------------------
#* Configuración de Supabase (Requerido para People Hub)
# ----------------------------------------------------------------------------
# Encuentra estos valores en tu panel de Supabase:
# https://supabase.com/dashboard/project/ylkwhejmcymlowcqgibn/settings/api
#
# IMPORTANTE: Las variables NEXT_PUBLIC_* son expuestas al navegador.
# NUNCA expongas SUPABASE_SERVICE_ROLE_KEY al cliente.
# ----------------------------------------------------------------------------

# URL de tu proyecto Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://ylkwhejmcymlowcqgibn.supabase.co

# Clave anónima pública (Settings > API > anon public)
# Esta clave es segura para el navegador, respeta RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlsa3doZWptY3ltbG93Y3FnaWJuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkxNzMyNzUsImV4cCI6MjA4NDc0OTI3NX0.pVw668j_GNCz-DXTLrwAGJEv9eTmoSEJPtvJ7aozpd4'

# Clave de servicio (Settings > API > service_role)
# SOLO para servidor, bypasses RLS - NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlsa3doZWptY3ltbG93Y3FnaWJuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2OTE3MzI3NSwiZXhwIjoyMDg0NzQ5Mjc1fQ.bRlh6eLtDBf9iqjmluHooeTseWn8eblJMv5tUmsQEoE'

# ----------------------------------------------------------------------------
#* Configuración de la Aplicación
# ----------------------------------------------------------------------------
# La URL base de tu aplicación, utilizada para redirecciones de autenticación.
# En desarrollo local, generalmente es http://localhost:3000, pero en producción será la URL de tu ambiente deployado.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
#* Configuración de Email (Resend)
# ----------------------------------------------------------------------------
# Crea una cuenta en https://resend.com y genera una API key.
# En desarrollo puedes usar el dominio de prueba de Resend (onboarding@resend.dev).
# En producción, verifica tu dominio en el panel de Resend.
#
# NUNCA expongas esta clave al cliente (sin prefijo NEXT_PUBLIC_).
# ----------------------------------------------------------------------------

# API Key de Resend (Settings > API Keys en resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe ser un dominio verificado en Resend)
# En desarrollo puedes usar: onboarding@resend.dev
EMAIL_FROM=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser (Next.js)
# - Never commit real values to git
# - Keep this .env.example file updated when adding new variables
# - Use descriptive comments to help your team understand each variable
# - For local development, you might want to create .env (also gitignored)
# ----------------------------------------------------------------------------
